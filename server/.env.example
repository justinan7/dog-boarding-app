# Copy to .env for local dev. Never commit real secrets — in prod these come
# from sops-nix (see ../infra/secrets/README.md), loaded as a systemd
# EnvironmentFile.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database ---------------------------------------------------------------
# The driver is chosen by URL scheme:
#   pglite://memory        → in-process WASM Postgres, in-memory (ephemeral)
#   pglite://.data/dev     → in-process WASM Postgres, persisted to ./.data/dev
#   postgresql://user:pass@host:5432/db  → real Postgres (node-postgres) [prod]
#
# Local dev with ZERO infrastructure (default):
DATABASE_URL=pglite://.data/dev
#
# Prod (NixOS VPS) uses the real cluster over loopback:
# DATABASE_URL=postgresql://zoomez:CHANGE_ME@127.0.0.1:5432/zoomez

# --- Auth (task B3) ---------------------------------------------------------
# BETTER_AUTH_SECRET=

# --- Object storage / Garage S3 (task B7) -----------------------------------
# S3_ENDPOINT=
# S3_REGION=garage
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Realtime / Centrifugo (task B6) ----------------------------------------
# CENTRIFUGO_HTTP_API_KEY=
# CENTRIFUGO_TOKEN_HMAC_SECRET_KEY=
