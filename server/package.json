{
  "name": "zoomez-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Zoomez API monolith — Node/TS + Hono + Drizzle + Postgres (see ../docs/api-contract.md)",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "tsx watch src/api.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsup",
    "start": "node dist/api.js",
    "start:worker": "node dist/worker.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "2.0.8",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.28",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@types/node": "26.1.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
